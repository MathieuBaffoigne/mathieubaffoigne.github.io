---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { defaultLang } from "../i18n/ui";

interface Props {
  title: string;
  description?: string;
  altPath?: string;
  rssHref?: string;
  jsonLd?: Record<string, unknown>;
  noindex?: boolean;
}

const {
  title,
  description = "Portfolio de Mathieu Baffoigne — Développeur fullstack (Angular, Python, AWS).",
  altPath,
  rssHref,
  jsonLd,
  noindex,
} = Astro.props;

const lang = Astro.currentLocale ?? defaultLang;
const currentPath = Astro.url.pathname;
const frHref = lang === "fr" ? currentPath : altPath;
const enHref = lang === "en" ? currentPath : altPath;

const canonicalUrl = new URL(currentPath, Astro.site);
const ogImageUrl = new URL("og-image.png", Astro.site);
const ogLocale = lang === "en" ? "en_US" : "fr_FR";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Mathieu Baffoigne",
  jobTitle: lang === "en" ? "Fullstack Developer" : "Développeur fullstack",
  url: Astro.site?.toString(),
  sameAs: ["https://github.com/mathieubaffoigne", "https://www.linkedin.com/in/mathieubaffoigne"],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script define:vars={{ lang, altPath }} is:inline>
      (function () {
        // Only auto-redirect on a visitor's first encounter with the site — once a
        // preference exists (detected here, or set explicitly via the header
        // switcher), never override it again.
        if (localStorage.getItem("lang-pref")) return;
        var detected = navigator.language || (navigator.languages && navigator.languages[0]) || "";
        // Undetectable language falls back to English, not French.
        var targetLang = detected.toLowerCase().indexOf("fr") === 0 ? "fr" : "en";
        if (targetLang !== lang && altPath) {
          localStorage.setItem("lang-pref", targetLang);
          location.replace(altPath);
          return;
        }
        localStorage.setItem("lang-pref", lang);
      })();
    </script>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Mathieu Baffoigne" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Mathieu Baffoigne — Développeur fullstack" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {frHref && enHref && (
      <>
        <link rel="alternate" hreflang="fr" href={frHref} />
        <link rel="alternate" hreflang="en" href={enHref} />
      </>
    )}
    {rssHref && (
      <link
        rel="alternate"
        type="application/rss+xml"
        title={lang === "en" ? "Blog RSS feed" : "Flux RSS du blog"}
        href={rssHref}
      />
    )}

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} is:inline />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />}

    <ClientRouter />
    <script is:inline>
      (function () {
        const getTheme = () =>
          localStorage.getItem("theme") ||
          (window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark");
        document.documentElement.setAttribute("data-theme", getTheme());
        // ClientRouter swaps <html> attributes with the freshly fetched (script-less)
        // document on every navigation, which would otherwise wipe data-theme. Stamp
        // the incoming document with the current theme before that swap happens.
        document.addEventListener("astro:before-swap", (event) => {
          event.newDocument.documentElement.setAttribute(
            "data-theme",
            document.documentElement.getAttribute("data-theme"),
          );
        });
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col bg-bg font-sans text-fg antialiased">
    <Header altPath={altPath} />
    <div class="flex flex-1 flex-col">
      <slot />
    </div>
    <Footer />
    <script>
      function initReveal() {
        const items = document.querySelectorAll<HTMLElement>(".reveal:not(.is-visible)");
        if (!items.length) return;
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15 },
        );
        items.forEach((el) => observer.observe(el));
      }
      document.addEventListener("astro:page-load", initReveal);
    </script>
  </body>
</html>
