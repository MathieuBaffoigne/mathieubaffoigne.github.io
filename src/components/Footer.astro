---
import { defaultLang, useTranslations } from "../i18n/ui";

const year = new Date().getFullYear();
const lang = Astro.currentLocale ?? defaultLang;
const t = useTranslations(lang);
---

<footer>
  <div
    class="mx-auto flex max-w-5xl flex-col gap-4 border-t border-border px-4 py-10 text-sm text-fg-muted sm:flex-row sm:items-center sm:justify-between sm:px-6"
  >
    <p>&copy; {year} Mathieu Baffoigne. {t("footer.built")}</p>
    <div class="flex justify-center gap-5 sm:justify-start">
      <a
        href="https://github.com/mathieubaffoigne"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link hover:text-fg"
      >
        GitHub
      </a>
      <a
        href="https://www.linkedin.com/in/mathieubaffoigne"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link hover:text-fg"
      >
        LinkedIn
      </a>
      <a href="mailto:mathieubaffoigne@protonmail.com" class="nav-link hover:text-fg">Email</a>
    </div>
  </div>
</footer>
