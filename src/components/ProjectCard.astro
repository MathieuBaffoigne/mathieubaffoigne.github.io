---
import { defaultLang, useTranslations } from "../i18n/ui";
import { techLinks } from "../data/tech-links";

interface Props {
  title: string;
  description: string;
  stack: string[];
  repoUrl?: string;
  demoUrl?: string;
  inProgress?: boolean;
}

const { title, description, stack, repoUrl, demoUrl, inProgress } = Astro.props;
const lang = Astro.currentLocale ?? defaultLang;
const t = useTranslations(lang);

const primaryUrl = demoUrl ?? repoUrl;
const primaryLabel = demoUrl ? t("card.demo") : t("card.code");
const secondaryUrl = demoUrl && repoUrl ? repoUrl : undefined;
---

<article class="reveal group relative rounded-xl border-2 border-border/50 bg-bg-soft p-6 transition-colors hover:border-accent">
  <div class="flex items-start justify-between gap-3">
    <h3 class:list={["text-lg font-semibold", primaryUrl && "transition-colors group-hover:text-accent"]}>{title}</h3>
    {
      inProgress && (
        <span class="inline-flex shrink-0 items-center gap-1.5 rounded-full border border-accent/60 px-2.5 py-0.5 font-mono text-xs text-accent">
          <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true" />
          {t("card.inProgress")}
        </span>
      )
    }
  </div>
  <p class="mt-2 text-sm text-fg-muted">{description}</p>
  <ul class="relative z-10 mt-4 flex flex-wrap gap-2">
    {
      stack.map((tech) =>
        techLinks[tech] ? (
          <li>
            <a
              href={techLinks[tech].url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-full border border-border px-2.5 py-0.5 font-mono text-xs text-fg-muted transition hover:-translate-y-0.5 hover:border-accent hover:bg-accent/10 hover:text-accent"
            >
              {techLinks[tech].icon && (
                <svg viewBox="0 0 24 24" class="h-3 w-3 shrink-0" fill="currentColor" aria-hidden="true">
                  <path d={techLinks[tech].icon} />
                </svg>
              )}
              {tech}
            </a>
          </li>
        ) : (
          <li class="rounded-full border border-border px-2.5 py-0.5 font-mono text-xs text-fg-muted">{tech}</li>
        ),
      )
    }
  </ul>
  <div class="mt-4 flex gap-4 text-sm">
    {
      primaryUrl && (
        <a href={primaryUrl} target="_blank" rel="noopener noreferrer" class="stretched-link text-accent hover:underline">
          {primaryLabel}
        </a>
      )
    }
    {
      secondaryUrl && (
        <a
          href={secondaryUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="relative z-10 text-fg-muted hover:text-fg hover:underline"
        >
          {t("card.code")}
        </a>
      )
    }
  </div>
</article>
