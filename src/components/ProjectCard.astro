---
import { defaultLang, useTranslations } from "../i18n/ui";
import { techLinks } from "../data/tech-links";

interface Props {
  title: string;
  description: string;
  stack: string[];
  repoUrl?: string;
  demoUrl?: string;
  inProgress?: boolean;
  openSource?: boolean;
  orgName?: string;
  orgUrl?: string;
  orgLogo?: string;
}

const { title, description, stack, repoUrl, demoUrl, inProgress, openSource, orgName, orgUrl, orgLogo } = Astro.props;
const lang = Astro.currentLocale ?? defaultLang;
const t = useTranslations(lang);

// demoUrl wins the primary (accent, whole-card) link slot; repoUrl is next;
// orgUrl only takes it when there's no demo or repo link to show instead.
const primaryKind = demoUrl ? "demo" : repoUrl ? "repo" : orgUrl ? "org" : undefined;
const primaryUrl = demoUrl ?? repoUrl ?? orgUrl;
// A repoUrl paired with an orgName isn't a project-specific repo — it's the
// org's GitHub profile (e.g. Missterry). Short "Profil"/"Site" labels (rather
// than "Profil GitHub"/orgName) keep both footer links on one line at card width.
const repoLabel = orgName ? t("card.profile") : t("card.code");
const primaryLabel = primaryKind === "demo" ? t("card.demo") : primaryKind === "org" ? orgName : repoLabel;
const secondaryUrl = demoUrl && repoUrl ? repoUrl : undefined;
const showOrgSecondary = !!orgUrl && primaryKind !== "org";

const githubIconPath =
  "M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12";
---

<article class="reveal group relative flex h-full flex-col rounded-xl border-2 border-border/50 bg-bg-soft p-6 transition-colors hover:border-accent">
  <div class="flex items-start justify-between gap-3">
    <h3 class:list={["text-lg font-semibold", primaryUrl && "transition-colors group-hover:text-accent"]}>{title}</h3>
    {
      inProgress && (
        <span class="inline-flex shrink-0 items-center gap-1.5 rounded-full border border-accent/60 px-2.5 py-0.5 font-mono text-xs text-accent">
          <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true" />
          {t("card.inProgress")}
        </span>
      )
    }
  </div>
  <p class="mt-2 text-sm text-fg-muted">{description}</p>
  {
    openSource && (
      <span class="relative z-10 mt-3 inline-flex items-center gap-2 text-sm text-accent" title={t("card.openSource")}>
        <svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
        </svg>
        {t("card.openSource")}
      </span>
    )
  }
  <ul class="relative z-10 mt-4 flex flex-wrap gap-2">
    {
      stack.map((tech) =>
        techLinks[tech] ? (
          <li>
            <a
              href={techLinks[tech].url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-full border border-border px-2.5 py-0.5 font-mono text-xs text-fg-muted transition hover:-translate-y-0.5 hover:border-accent hover:bg-accent/10 hover:text-accent"
            >
              {techLinks[tech].icon && (
                <svg viewBox="0 0 24 24" class="h-3 w-3 shrink-0" fill="currentColor" aria-hidden="true">
                  <path d={techLinks[tech].icon} />
                </svg>
              )}
              {tech}
            </a>
          </li>
        ) : (
          <li class="rounded-full border border-border px-2.5 py-0.5 font-mono text-xs text-fg-muted">{tech}</li>
        ),
      )
    }
  </ul>
  <div class="mt-auto flex flex-wrap items-center justify-between gap-x-6 gap-y-3 pt-5 text-sm">
    <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
      {
        primaryUrl && (
          <a
            href={primaryUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="stretched-link inline-flex items-center gap-2 text-accent hover:underline"
          >
            {primaryKind === "repo" && (
              <svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0" fill="currentColor" aria-hidden="true">
                <path d={githubIconPath} />
              </svg>
            )}
            {primaryKind === "org" && orgLogo && (
              <img src={orgLogo} alt="" class="h-4 w-4 shrink-0 rounded-full" loading="lazy" />
            )}
            {primaryLabel}
          </a>
        )
      }
      {
        secondaryUrl && (
          <a
            href={secondaryUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="relative z-10 inline-flex items-center gap-2 text-fg-muted hover:text-fg hover:underline"
          >
            <svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0" fill="currentColor" aria-hidden="true">
              <path d={githubIconPath} />
            </svg>
            {repoLabel}
          </a>
        )
      }
    </div>
    {
      showOrgSecondary && (
        <a
          href={orgUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="relative z-10 ml-auto inline-flex shrink-0 items-center gap-2 text-accent hover:underline"
        >
          {orgLogo && <img src={orgLogo} alt="" class="h-4 w-4 shrink-0 rounded-full" loading="lazy" />}
          {t("card.website")}
        </a>
      )
    }
  </div>
</article>
