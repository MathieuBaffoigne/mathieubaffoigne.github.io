---
import BaseLayout from "../../layouts/BaseLayout.astro";

const email = "mathieubaffoigne@protonmail.com";
---

<BaseLayout
  title="Contact — Mathieu Baffoigne"
  description="Let's talk about your project or an opportunity."
  altPath="/contact"
>
  <main class="mx-auto max-w-2xl px-4 pt-14 pb-20 sm:px-6">
    <h1 class="reveal text-3xl font-bold">Contact</h1>
    <p class="reveal mt-3 text-fg-muted">
      Based in Bègles, near Bordeaux, France — open to fullstack opportunities locally or remote, freelance work,
      and one-off collaborations. Easiest way to reach me: send an email, I reply within 48h.
    </p>
    <a
      href={`mailto:${email}`}
      class="reveal mt-8 inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-3 font-medium text-accent-fg transition hover:-translate-y-0.5 hover:bg-accent-hover"
    >
      Send an email
    </a>
  </main>
</BaseLayout>
