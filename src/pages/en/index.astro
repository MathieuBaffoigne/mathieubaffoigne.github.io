---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects", ({ data }) => data.lang === "en" && data.featured))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const posts = (await getCollection("blog", ({ data }) => data.lang === "en" && !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
---

<BaseLayout
  title="Mathieu Baffoigne — Fullstack developer"
  description="Portfolio of Mathieu Baffoigne — Fullstack developer (Angular, Python, AWS). Projects, journey, and blog."
  altPath="/"
>
  <main class="mx-auto max-w-5xl px-4 sm:px-6">
    <section class="reveal pt-10 pb-14 sm:pt-12 sm:pb-16">
      <p class="font-mono text-sm text-accent">Fullstack developer, open to new opportunities</p>
      <h1 class="mt-4 max-w-2xl text-4xl font-bold tracking-tight sm:text-5xl">
        I build web products that are fast, polished, and built to last.
      </h1>
      <p class="mt-6 max-w-xl text-lg text-fg-muted">
        From prototype to production: interfaces, APIs, lightweight infrastructure. I also write about what I learn
        along the way.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/en/projects"
          class="rounded-lg bg-accent px-5 py-2.5 text-sm font-medium text-accent-fg transition hover:-translate-y-0.5 hover:bg-accent-hover"
        >
          View my projects
        </a>
        <a
          href="/en/contact"
          class="rounded-lg border-2 border-border/60 px-5 py-2.5 text-sm font-medium transition hover:-translate-y-0.5 hover:border-accent hover:bg-accent/10"
        >
          Get in touch
        </a>
      </div>
    </section>

    <section class="reveal border-t border-border pt-10 pb-16">
      <h2 class="section-label font-mono text-sm uppercase tracking-wide text-fg-muted">Recent projects</h2>
      <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          projects.map((project) => (
            <ProjectCard
              title={project.data.title}
              description={project.data.description}
              stack={project.data.stack}
              repoUrl={project.data.repoUrl}
              demoUrl={project.data.demoUrl}
              inProgress={project.data.inProgress}
              openSource={project.data.openSource}
              orgName={project.data.orgName}
              orgUrl={project.data.orgUrl}
              orgLogo={project.data.orgLogo}
            />
          ))
        }
      </div>
    </section>

    <section class="reveal border-t border-border pt-10 pb-16">
      <h2 class="section-label font-mono text-sm uppercase tracking-wide text-fg-muted">Latest posts</h2>
      <div class="mt-6 grid gap-6 sm:grid-cols-2">
        {
          posts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              slug={post.id.replace(/^en\//, "")}
            />
          ))
        }
      </div>
    </section>

    <section class="reveal mb-24 border-t border-border pt-10 pb-16">
      <h2 class="text-2xl font-semibold">Want to collaborate?</h2>
      <p class="mt-3 max-w-xl text-fg-muted">
        Open to fullstack opportunities in the Bordeaux area or remote, freelance work, or one-off collaborations.
      </p>
      <a
        href="/en/contact"
        class="mt-6 inline-block rounded-lg bg-accent px-5 py-2.5 text-sm font-medium text-accent-fg transition hover:-translate-y-0.5 hover:bg-accent-hover"
      >
        Let's talk about your project
      </a>
    </section>
  </main>
</BaseLayout>
