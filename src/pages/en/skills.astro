---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SkillGroup from "../../components/SkillGroup.astro";
import { getSkillGroups, getCertGroups } from "../../data/skills";

const groups = getSkillGroups();
const certGroups = getCertGroups("en");
---

<BaseLayout
  title="Skills — Mathieu Baffoigne"
  description="Technical stack and tools used day to day."
  altPath="/competences"
>
  <main class="mx-auto max-w-5xl px-4 pt-10 pb-20 sm:pt-12 sm:px-6">
    <h1 class="reveal text-3xl font-bold">Skills</h1>
    <p class="reveal mt-3 max-w-xl text-fg-muted">
      The stack I work with the most, from design to production.
    </p>
    <div class="mt-10 grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
      {groups.map((group) => <SkillGroup title={group.title} skills={group.skills} />)}
    </div>
    <div class="mt-16 border-t border-border pt-10">
      <h2 class="section-label font-mono text-sm uppercase tracking-wide text-fg-muted">Certifications</h2>
      <div class="mt-6 grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
        {certGroups.map((group) => <SkillGroup title={group.title} skills={group.skills} />)}
      </div>
    </div>
  </main>
</BaseLayout>
