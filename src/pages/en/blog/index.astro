---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BlogCard from "../../../components/BlogCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => data.lang === "en" && !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout
  title="Blog — Mathieu Baffoigne"
  description="Notes on web development, architecture, and what I learn building projects."
  altPath="/blog"
  rssHref="/en/rss.xml"
>
  <main class="mx-auto max-w-5xl px-4 pt-10 pb-20 sm:pt-12 sm:px-6">
    <h1 class="reveal text-3xl font-bold">Blog</h1>
    <p class="reveal mt-3 max-w-xl text-fg-muted">Notes on what I learn building projects.</p>
    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      {
        posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.id.replace(/^en\//, "")}
          />
        ))
      }
    </div>
  </main>
</BaseLayout>
