---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimelineItem from "../components/TimelineItem.astro";

const timeline = [
  {
    date: "Projet en cours",
    title: "VAE Ingénieur en informatique",
    place: "Validation des acquis de l'expérience",
    description:
      "Démarche de VAE en cours pour faire valider un titre d'ingénieur en informatique sur la base de l'expérience professionnelle acquise depuis la reconversion.",
  },
  {
    date: "2025 — Aujourd'hui",
    title: "Ingénieur logiciel",
    place: "CGI, Le Haillan",
    description:
      "Développement d'applications fullstack dans le secteur de l'eau (facturation, gestion des consommations), plusieurs millions d'opérations traitées par an. APIs Python (FastAPI, Chalice, Django) et interfaces Angular, sur une architecture AWS serverless (Lambda, API Gateway, DynamoDB).",
  },
  {
    date: "2022 — 2024",
    title: "Développeur Full Stack (alternance) & formation IA",
    place: "onepoint & Simplon.co Grand Ouest, Bègles",
    description:
      "Développement d'une application interne de gestion du personnel (Angular, Flask, MySQL, Docker), en alternance avec une formation développeur en intelligence artificielle chez Simplon.co.",
  },
  {
    date: "2021",
    title: "Formation développeur web fullstack JS",
    place: "École O'clock",
    description: "Bootcamp intensif déclencheur de la reconversion : bases du développement web fullstack en JavaScript.",
  },
  {
    date: "2013 — 2021",
    title: "Technicien métrologie & contrôle qualité",
    place: "Secteur aéronautique et automobile (Safran, Valeo, Laroche Group...)",
    description:
      "Plusieurs années de contrôle dimensionnel de haute précision sur pièces critiques, dont un poste de technicien laser tracker chez Laroche Group. Formation initiale : DUT Génie Mécanique (IUT Bordeaux) et Licence pro Contrôle Qualité Métrologie (IUT Figeac).",
  },
];
---

<BaseLayout
  title="Parcours — Mathieu Baffoigne"
  description="Expériences professionnelles et formation."
  altPath="/en/journey"
>
  <main class="mx-auto max-w-3xl px-4 pt-14 pb-20 sm:px-6">
    <h1 class="reveal text-3xl font-bold">Parcours</h1>
    <p class="reveal mt-3 text-fg-muted">Un résumé de mon expérience professionnelle et de ma formation.</p>
    <ol class="relative mt-12 space-y-10 border-l border-border pl-2">
      {timeline.map((item) => <TimelineItem {...item} />)}
    </ol>
  </main>
</BaseLayout>
