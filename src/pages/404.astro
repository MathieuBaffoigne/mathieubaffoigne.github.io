---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Mathieu Baffoigne" description="Page introuvable." noindex>
  <main class="mx-auto flex flex-1 max-w-2xl flex-col items-center justify-center px-4 text-center sm:px-6">
    <div data-404-lang="fr">
      <p class="reveal font-mono text-7xl font-extrabold text-accent sm:text-8xl">404</p>
      <h1 class="reveal mt-4 text-3xl font-bold">Page introuvable</h1>
      <p class="reveal mt-3 text-fg-muted">Cette page n'existe pas, ou plus.</p>
      <a
        href="/"
        class="reveal mt-8 inline-block rounded-lg bg-accent px-5 py-2.5 text-sm font-medium text-accent-fg transition hover:-translate-y-0.5 hover:bg-accent-hover"
      >
        Retour à l'accueil
      </a>
    </div>

    <div data-404-lang="en" hidden>
      <p class="reveal font-mono text-7xl font-extrabold text-accent sm:text-8xl">404</p>
      <h1 class="reveal mt-4 text-3xl font-bold">Page not found</h1>
      <p class="reveal mt-3 text-fg-muted">This page doesn't exist, or not anymore.</p>
      <a
        href="/en"
        class="reveal mt-8 inline-block rounded-lg bg-accent px-5 py-2.5 text-sm font-medium text-accent-fg transition hover:-translate-y-0.5 hover:bg-accent-hover"
      >
        Back home
      </a>
    </div>
  </main>
  <script is:inline>
    (function () {
      // Static 404 page: no server-side way to know which locale the visitor
      // was on, so pick a display language the same way BaseLayout does
      // (stored preference, else browser language) and show only that block.
      var pref = localStorage.getItem("lang-pref");
      var lang = pref || ((navigator.language || "").toLowerCase().indexOf("fr") === 0 ? "fr" : "en");
      if (lang === "en") {
        document.querySelector('[data-404-lang="fr"]').hidden = true;
        document.querySelector('[data-404-lang="en"]').hidden = false;
      }
    })();
  </script>
</BaseLayout>
